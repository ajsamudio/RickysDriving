# ─── Supabase ─────────────────────────────────────────────────────────────
# Find these in your Supabase project → Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...
# Service-role key — bypasses RLS. Server-only, NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# ─── Stripe ───────────────────────────────────────────────────────────────
# Dashboard → Developers → API keys. Use test keys (sk_test_…) in development.
STRIPE_SECRET_KEY=sk_test_...
# Webhook signing secret. Run `stripe listen --forward-to localhost:3000/api/stripe/webhook`
# to get one locally.
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── App ──────────────────────────────────────────────────────────────────
# Used for Stripe success/cancel URLs. Change to your production URL when deployed.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Resend (transactional email) ─────────────────────────────────────────
# resend.com → API keys. Sender domain must be verified in Resend.
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=bookings@rickysdriving.com
# Where new-booking notifications go (Ricky's inbox).
INSTRUCTOR_EMAIL=ricky@rickysdriving.com
